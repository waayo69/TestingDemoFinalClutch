@model TestingDemo.ViewModels.DashboardViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Queue Monitor - Standalone Monitor</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/darkmode.css" asp-append-version="true" />
    <style>
        /* Ultra-Minimalist Professional Monitor Dashboard */
        :root {
            --m-bg: #0f172a;
            --m-bg-soft: #1e293b;
            --m-text: #f8fafc;
            --m-text-muted: #94a3b8;
            --m-border: #334155;
            --m-font-card: 1.1rem;
            --m-font-title: 2rem;
        }

        body {
            background-color: var(--m-bg);
            color: var(--m-text);
            margin: 0;
            padding: 0;
            overflow: hidden; /* Prevent body scroll */
            font-family: 'Inter', sans-serif;
        }

        .monitor-wrapper {
            display: flex;
            flex-direction: column;
            height: 100vh;
            padding: 1.5rem;
            box-sizing: border-box;
        }

        .monitor-header {
            flex: 0 0 auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
            padding-bottom: 1rem;
            border-bottom: 2px solid var(--m-border);
        }

        .monitor-title h1 {
            font-size: var(--m-font-title);
            font-weight: 800;
            margin: 0;
            letter-spacing: -0.04em;
        }

        .monitor-stats {
            display: flex;
            gap: 4rem;
            font-size: 1.2rem;
            color: var(--m-text-muted);
            align-items: center;
        }

        .stat-val { font-weight: 700; color: var(--m-text); }

        .queue-grid {
            flex: 1 1 auto;
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 1.25rem;
            overflow: hidden; /* Grid itself doesn't scroll */
        }

        .queue-col {
            display: flex;
            flex-direction: column;
            height: 100%;
            background: rgba(255,255,255,0.02);
            border-radius: 12px;
            border: 1px solid var(--m-border);
            overflow: hidden;
        }

        .col-header {
            flex: 0 0 auto;
            font-size: 0.85rem;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: 0.15em;
            padding: 1rem;
            background: var(--m-bg-soft);
            border-bottom: 3px solid var(--m-border);
            text-align: center;
        }

        /* Color Coding */
        .h-finance { border-color: #3b82f6; color: #60a5fa; }
        .h-planning { border-color: #8b5cf6; color: #a78bfa; }
        .h-liaison { border-color: #f59e0b; color: #fbbf24; }
        .h-filing { border-color: #10b981; color: #34d399; }
        .h-claiming { border-color: #ec4899; color: #f472b6; }

        .client-list {
            flex: 1 1 auto;
            overflow-y: auto;
            padding: 0.75rem;
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
        }

        /* Hide Scrollbar but keep functionality */
        .client-list::-webkit-scrollbar { width: 4px; }
        .client-list::-webkit-scrollbar-thumb { background: var(--m-border); border-radius: 10px; }

        .client-card {
            background: var(--m-bg-soft);
            border: 1px solid var(--m-border);
            border-radius: 10px;
            padding: 1rem;
            position: relative;
        }

        .card-meta {
            display: flex;
            justify-content: space-between;
            font-size: 0.8rem;
            font-weight: 800;
            color: var(--m-text-muted);
            margin-bottom: 0.5rem;
        }

        .card-name {
            font-size: var(--m-font-card);
            font-weight: 800;
            margin-bottom: 0.75rem;
            color: var(--m-text);
            line-height: 1.2;
        }

        .card-details {
            font-size: 0.9rem;
            color: var(--m-text-muted);
            margin-bottom: 1rem;
            font-weight: 500;
        }

        .card-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.95rem;
            padding-top: 0.75rem;
            border-top: 1px solid var(--m-border);
        }

        .assigned-to {
            color: #e2e8f0;
            font-weight: 700;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

        .assigned-label { color: var(--m-text-muted); font-size: 0.8rem; font-weight: 600; }

        .queue-timer {
            color: var(--m-text-muted);
            font-weight: 800;
            font-variant-numeric: tabular-nums;
        }

        .urgency-dot { width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-right: 5px; }
        .urgency-urgent { background-color: #ef4444; box-shadow: 0 0 10px rgba(239, 68, 68, 0.4); }
        .urgency-sl-urgent { background-color: #f59e0b; }
        .urgency-normal { background-color: #10b981; }

        .empty-state {
            padding: 2.5rem;
            text-align: center;
            color: var(--m-text-muted);
            font-size: 1rem;
            opacity: 0.5;
            font-style: italic;
        }

        .live-indicator { display: inline-flex; align-items: center; gap: 0.75rem; color: #34d399; font-weight: 800; font-size: 1rem; }
        .pulse-dot { width: 10px; height: 10px; background: currentColor; border-radius: 50%; animation: pulse 2s infinite; }
        @@keyframes pulse { 0% { transform: scale(1); opacity: 1; } 50% { transform: scale(1.8); opacity: 0; } 100% { transform: scale(1); opacity: 0; } }

        #liveClock { font-size: 1.75rem; font-weight: 900; color: #fff; }
    </style>
</head>
<body>
    <div class="monitor-wrapper">
        <header class="monitor-header">
            <div class="monitor-title">
                <h1>REAL-TIME QUEUE MONITOR</h1>
                <div class="live-indicator">
                    <span class="pulse-dot"></span>
                    LIVE STREAM ACTIVE
                </div>
            </div>
            <div class="monitor-stats">
                <div id="liveClock">--:--:--</div>
            </div>
        </header>

        <div class="queue-grid">
            <!-- FINANCE -->
            <div class="queue-col">
                <div class="col-header h-finance">Finance (@Model.FinanceClients.Count)</div>
                <div class="client-list">
                    @if (Model.FinanceClients?.Any() == true)
                    {
                        @foreach (var item in Model.FinanceClients)
                        {
                            <div class="client-card">
                                <div class="card-meta">
                                    <span>#@item.Client.TrackingNumber</span>
                                    <span><span class="urgency-dot urgency-@(item.Client.UrgencyLevel.ToLower().Replace(" ", "-"))"></span>@item.Client.UrgencyLevel</span>
                                </div>
                                <div class="card-name">@item.Client.ClientName</div>
                                <div class="card-details">@item.Client.TypeOfProject</div>
                                <div class="card-footer">
                                    <div class="assigned-to">
                                        <span class="assigned-label">PIC:</span>
                                        <span>@(item.AssignedUserName ?? "Unassigned")</span>
                                    </div>
                                    <div class="queue-timer" data-start="@item.Client.CreatedDate.ToString("o")">0m</div>
                                </div>
                            </div>
                        }
                    }
                    else { <div class="empty-state">Queue Empty</div> }
                </div>
            </div>

            <!-- PLANNING -->
            <div class="queue-col">
                <div class="col-header h-planning">Planning Officer (@Model.PlanningClients.Count)</div>
                <div class="client-list">
                    @if (Model.PlanningClients?.Any() == true)
                    {
                        @foreach (var item in Model.PlanningClients)
                        {
                            <div class="client-card">
                                <div class="card-meta">
                                    <span>#@item.Client.TrackingNumber</span>
                                    <span><span class="urgency-dot urgency-@(item.Client.UrgencyLevel.ToLower().Replace(" ", "-"))"></span>@item.Client.UrgencyLevel</span>
                                </div>
                                <div class="card-name">@item.Client.ClientName</div>
                                <div class="card-details">@item.Client.RegisteredCompanyAddress</div>
                                <div class="card-footer">
                                    <div class="assigned-to">
                                        <span class="assigned-label">PIC:</span>
                                        <span>@(item.AssignedUserName ?? "Unassigned")</span>
                                    </div>
                                    <div class="queue-timer" data-start="@item.Client.CreatedDate.ToString("o")">0m</div>
                                </div>
                            </div>
                        }
                    }
                    else { <div class="empty-state">Queue Empty</div> }
                </div>
            </div>

            <!-- LIAISON -->
            <div class="queue-col">
                <div class="col-header h-liaison">Customer Care (@(Model.LiaisonClients.Count + Model.ReceivedClients.Count))</div>
                <div class="client-list">
                    @{ var lClients = Model.LiaisonClients.Concat(Model.ReceivedClients).ToList(); }
                    @if (lClients.Any())
                    {
                        @foreach (var item in lClients)
                        {
                            <div class="client-card">
                                <div class="card-meta">
                                    <span>#@item.Client.TrackingNumber</span>
                                    <span><span class="urgency-dot urgency-@(item.Client.UrgencyLevel.ToLower().Replace(" ", "-"))"></span>@item.Client.UrgencyLevel</span>
                                </div>
                                <div class="card-name">@item.Client.ClientName</div>
                                <div class="card-details">@item.Client.ContactPersonNumber</div>
                                <div class="card-footer">
                                    <div class="assigned-to">
                                        <span class="assigned-label">PIC:</span>
                                        <span>@(item.AssignedUserName ?? "Unassigned")</span>
                                    </div>
                                    <div class="queue-timer" data-start="@item.Client.CreatedDate.ToString("o")">0m</div>
                                </div>
                            </div>
                        }
                    }
                    else { <div class="empty-state">Queue Empty</div> }
                </div>
            </div>

            <!-- FILING -->
            <div class="queue-col">
                <div class="col-header h-filing">Documentation(@Model.DocumentationClients.Count)</div>
                <div class="client-list">
                    @if (Model.DocumentationClients?.Any() == true)
                    {
                        @foreach (var item in Model.DocumentationClients)
                        {
                            <div class="client-card">
                                <div class="card-meta">
                                    <span>#@item.Client.TrackingNumber</span>
                                    <span><span class="urgency-dot urgency-@(item.Client.UrgencyLevel.ToLower().Replace(" ", "-"))"></span>@item.Client.UrgencyLevel</span>
                                </div>
                                <div class="card-name">@item.Client.ClientName</div>
                                <div class="card-details">@item.Client.SubStatus</div>
                                <div class="card-footer">
                                    <div class="assigned-to">
                                        <span class="assigned-label">PIC:</span>
                                        <span>@(item.AssignedUserName ?? "Unassigned")</span>
                                    </div>
                                    <div class="queue-timer" data-start="@item.Client.CreatedDate.ToString("o")">0m</div>
                                </div>
                            </div>
                        }
                    }
                    else { <div class="empty-state">Queue Empty</div> }
                </div>
            </div>

            <!-- CLEARANCE -->
            <div class="queue-col">
                <div class="col-header h-claiming">Finance (Clearance) (@Model.ClearanceClients.Count)</div>
                <div class="client-list">
                    @if (Model.ClearanceClients?.Any() == true)
                    {
                        @foreach (var item in Model.ClearanceClients)
                        {
                            <div class="client-card">
                                <div class="card-meta">
                                    <span>#@item.Client.TrackingNumber</span>
                                    <span><span class="urgency-dot urgency-@(item.Client.UrgencyLevel.ToLower().Replace(" ", "-"))"></span>@item.Client.UrgencyLevel</span>
                                </div>
                                <div class="card-name">@item.Client.ClientName</div>
                                <div class="card-details">READY FOR CLAIMING</div>
                                <div class="card-footer">
                                    <div class="assigned-to">
                                        <span class="assigned-label">PIC:</span>
                                        <span>@(item.AssignedUserName ?? "Finalized")</span>
                                    </div>
                                    <div class="queue-timer" data-start="@item.Client.CreatedDate.ToString("o")">0m</div>
                                </div>
                            </div>
                        }
                    }
                    else { <div class="empty-state">No Pending Claims</div> }
                </div>
            </div>
        </div>
    </div>

    <audio id="notifySound" src="/sounds/Notifications.mp3" preload="auto"></audio>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>
    <script>
        function updateUI() {
            const now = new Date();
            const clock = document.getElementById('liveClock');
            if (clock) clock.innerText = now.toLocaleTimeString();

            document.querySelectorAll('.queue-timer').forEach(timer => {
                const start = new Date(timer.dataset.start);
                const diff = Math.floor((now - start) / 60000);
                timer.innerText = diff < 60 ? `${diff}m` : `${Math.floor(diff/60)}h ${diff%60}m`;
                
                if (diff > 60) timer.style.color = '#ff4d4d';
                else if (diff > 30) timer.style.color = '#fbbf24';
            });
        }

        setInterval(updateUI, 1000);
        updateUI();

        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/notificationHub")
            .build();

        connection.on("ReceiveUpdate", function () {
            const audio = document.getElementById('notifySound');
            if (audio) audio.play().catch(() => {});
            setTimeout(() => location.reload(), 800);
        });

        connection.start().catch(function (err) {
            return console.error(err.toString());
        });
    </script>
</body>
</html>
