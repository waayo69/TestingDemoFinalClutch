@model TestingDemo.ViewModels.DocumentOfficerDashboardViewModel
@{
    ViewData["Title"] = "Document Officer Dashboard";
}

<div class="container py-4">
    <!-- Simple Header -->
    <div class="row mb-4 align-items-center">
        <div class="col-md-6">
            <h2 class="mb-0"><i class="bi bi-folder-check"></i> @ViewData["Title"]</h2>
            <p class="text-muted small mb-0">Verify requirements and prepare documents for clearance</p>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <!-- Optional: Add buttons here if needed -->
        </div>
    </div>

    <!-- Simple Search & Filters -->
    <div class="row mb-3 g-2">
        <div class="col-md-6">
            <form asp-action="Index" method="get" class="d-flex gap-2">
                <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" 
                       class="form-control" placeholder="Search tracking #, name..." />
                @if (!String.IsNullOrEmpty(ViewData["CurrentFilter"] as string))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary" title="Clear">
                        <i class="bi bi-x-lg"></i>
                    </a>
                }
                <button type="submit" class="btn btn-dark"><i class="bi bi-search"></i></button>
            </form>
        </div>
        <div class="col-md-6 d-flex justify-content-md-end gap-2">
            <div class="dropdown">
                <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                    <i class="bi bi-sort-down"></i> Sort By
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" asp-action="Index" asp-route-sortOrder="" asp-route-searchString="@ViewData["CurrentFilter"]">Name (A-Z)</a></li>
                    <li><a class="dropdown-item" asp-action="Index" asp-route-sortOrder="@ViewData["NameSortParm"]" asp-route-searchString="@ViewData["CurrentFilter"]">Name (Z-A)</a></li>
                    <li><a class="dropdown-item" asp-action="Index" asp-route-sortOrder="Date" asp-route-searchString="@ViewData["CurrentFilter"]">Date (Oldest)</a></li>
                    <li><a class="dropdown-item" asp-action="Index" asp-route-sortOrder="@ViewData["DateSortParm"]" asp-route-searchString="@ViewData["CurrentFilter"]">Date (Newest)</a></li>
                </ul>
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show mb-4 shadow-sm border-0 border-start border-4 border-success" role="alert">
            <div class="d-flex align-items-center">
                <i class="bi bi-check-circle-fill text-success fs-4 me-3"></i>
                <div>@TempData["SuccessMessage"]</div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <!-- Simple Tabbed Dashboard -->
    <div class="card border-0 shadow-sm rounded-3 overflow-hidden mb-5">
        <div class="card-header bg-light border-bottom">
            <ul class="nav nav-tabs card-header-tabs" id="docDashboardTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-bold" id="pending-tab" data-bs-toggle="tab" data-bs-target="#pending" type="button" role="tab">
                        <i class="bi bi-file-earmark-medical me-1"></i> Pending Documents
                        <small class="badge bg-secondary ms-1">@Model.PendingClients.TotalCount</small>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold" id="archive-tab" data-bs-toggle="tab" data-bs-target="#archive" type="button" role="tab">
                        <i class="bi bi-archive me-1"></i> Unified Archive
                        <small class="badge bg-secondary ms-1">@Model.ArchivedClients.TotalCount</small>
                    </button>
                </li>
            </ul>
        </div>

        <div class="tab-content" id="docDashboardTabsContent">
            <!-- Pending Documents Tab -->
            <div class="tab-pane fade show active" id="pending" role="tabpanel">
                @{ ViewData["IsArchived"] = false; }
                @await Html.PartialAsync("_DocumentOfficerTable", Model.PendingClients)
            </div>

            <!-- Unified Archive Tab -->
            <div class="tab-pane fade" id="archive" role="tabpanel">
                @{ ViewData["IsArchived"] = true; }
                @await Html.PartialAsync("_DocumentOfficerTable", Model.ArchivedClients)
            </div>
        </div>
    </div>
</div>
</div>

@* Client Details Modals (Looped for both lists) *@
@foreach (var item in Model.PendingClients)
{
    @await Html.PartialAsync("_ClientDetailsModal", item)
}
@foreach (var item in Model.ArchivedClients)
{
    @await Html.PartialAsync("_ClientDetailsModal", item)
}

<!-- Done Confirmation Modal -->
<div class="modal fade" id="doneModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-header border-0 pb-0 ps-4 pt-4 text-success">
                <h5 class="modal-title fw-bold"><i class="bi bi-check-circle-fill me-2"></i> Mark as Done</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <div class="mb-4 text-success bg-success bg-opacity-10 d-inline-flex align-items-center justify-content-center rounded-circle" style="width: 80px; height: 80px;">
                    <i class="bi bi-send-check fs-1"></i>
                </div>
                <h5 class="fw-bold text-dark">Proceed to Finance?</h5>
                <p class="text-muted px-3 mb-4">Are you sure you want to mark <strong id="doneClientName"></strong> as done? This will proceed the client to Finance for clearance.</p>
                <form id="doneModalForm" method="post" class="text-start">
                    <div class="mb-3 px-3">
                        <label for="assignedUserId" class="form-label fw-bold text-dark"><i class="bi bi-person-badge me-2"></i>Assign to Finance (Optional)</label>
                        <select class="form-select assign-fin-select" id="assignedUserId" name="assignedUserId">
                            <option value="">-- Unassigned (Available to all Finance Users) --</option>
                        </select>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-0 p-4 pt-0 justify-content-center">
                <button type="button" class="btn btn-light rounded-pill px-4 m-1" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success rounded-pill px-4 shadow-sm fw-bold m-1" id="confirmDoneBtn" onclick="document.getElementById('doneModalForm').submit()">
                    Yes, Proceed
                </button>
            </div>
        </div>
    </div>
</div>

<audio id="notifySound" src="/sounds/Notifications.wav" preload="auto"></audio>


@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Tab persistence
            const activeTabKey = 'doc_active_tab';
            const tabs = document.querySelectorAll('#docDashboardTabs button');
            
            const urlParams = new URLSearchParams(window.location.search);
            if (urlParams.has('archivedPageNumber')) {
                const tab = document.querySelector('#archive-tab');
                if (tab) bootstrap.Tab.getOrCreateInstance(tab).show();
            } else if (urlParams.has('pendingPageNumber')) {
                const tab = document.querySelector('#pending-tab');
                if (tab) bootstrap.Tab.getOrCreateInstance(tab).show();
            } else {
                const lastTab = localStorage.getItem(activeTabKey);
                if (lastTab) {
                    const tab = document.getElementById(lastTab);
                    if (tab) bootstrap.Tab.getOrCreateInstance(tab).show();
                }
            }

            tabs.forEach(tab => {
                tab.addEventListener('shown.bs.tab', (e) => {
                    localStorage.setItem(activeTabKey, e.target.id);
                });
            });

            // Done Confirmation Logic
            const doneModal = new bootstrap.Modal(document.getElementById('doneModal'));
            let clientIdToSubmit = null;

            document.addEventListener('click', function(e) {
                const btn = e.target.closest('.done-btn');
                if (btn) {
                    clientIdToSubmit = btn.getAttribute('data-client-id');
                    document.getElementById('doneClientName').textContent = btn.getAttribute('data-client-name');
                    
                    var form = document.getElementById('doneModalForm');
                    form.action = '/DocumentOfficer/ProceedToFinance/' + clientIdToSubmit;
                    
                    // Populate assigned Finance user dropdown
                    var select = form.querySelector('.assign-fin-select');
                    if (select && select.options.length <= 1) { // Only fetch if not already loaded
                        fetch('@Url.Action("GetFinanceUsers", "DocumentOfficer")')
                            .then(r => r.json())
                            .then(users => {
                                users.forEach(u => {
                                    var opt = document.createElement('option');
                                    opt.value = u.id;
                                    opt.textContent = u.name;
                                    select.appendChild(opt);
                                });
                            })
                            .catch(err => console.error('Failed to load Finance users', err));
                    }
                    
                    doneModal.show();
                }
            });

            // Details Modal Logic (Load files on show)
            document.addEventListener('shown.bs.modal', function (event) {
                var modal = event.target;
                if (!modal.id || !modal.id.startsWith('docClientModal-')) return;
                var clientId = modal.id.replace('docClientModal-', '');
                
                var filesElement = modal.querySelector('#requirement-files-' + clientId);
                if (filesElement) {
                    fetch('/DocumentOfficer/GetRequirementFiles?clientId=' + clientId + '&t=' + Date.now(), {
                        cache: 'no-store',
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    })
                    .then(r => r.text())
                    .then(html => { filesElement.innerHTML = html; })
                    .catch(() => { filesElement.innerHTML = '<div class="alert alert-warning">Failed to load requirement files.</div>'; });
                }
            });

            // SignalR Update Handling
            if (window.connection) {
                connection.on("ReceiveUpdate", function (message) {
                    location.reload();
                });
            }
        });

        // Global file viewer and upload handlers (same as original original)
        document.addEventListener('click', function (e) {
            // View file logic
            if (e.target.closest('.view-file-btn')) {
                const btn = e.target.closest('.view-file-btn');
                const fileUrl = btn.getAttribute('data-file-url');
                const fileName = btn.getAttribute('data-file-name');
                const fileType = btn.getAttribute('data-file-type').toLowerCase();
                
                document.getElementById('viewerFileName').textContent = fileName;
                document.getElementById('downloadFileBtn').href = fileUrl;
                
                const contentDiv = document.getElementById('fileViewerContent');
                if (['.jpg', '.jpeg', '.png', '.gif', '.wbep'].some(ext => fileType.includes(ext))) {
                    contentDiv.innerHTML = `<img src="${fileUrl}" class="img-fluid rounded shadow-sm" style="max-height: 70vh;" />`;
                } else if (fileType.includes('.pdf')) {
                    contentDiv.innerHTML = `<iframe src="${fileUrl}" style="width: 100%; height: 70vh; border: none;"></iframe>`;
                } else {
                    contentDiv.innerHTML = `<div class="text-center p-5"><i class="bi bi-file-earmark fs-1 text-muted mb-3"></i><h5>${fileName}</h5><p>Cannot preview this type.</p></div>`;
                }
                new bootstrap.Modal(document.getElementById('fileViewerModal')).show();
            }

            // Upload modal logic
            if (e.target.closest('.upload-files-btn')) {
                const btn = e.target.closest('.upload-files-btn');
                document.getElementById('uploadRequirementId').value = btn.getAttribute('data-requirement-id');
                document.getElementById('uploadRequirementName').textContent = btn.getAttribute('data-requirement-name');
                new bootstrap.Modal(document.getElementById('uploadFilesModal')).show();
            }

            // Delete file logic
            if (e.target.closest('.delete-file-btn')) {
                const btn = e.target.closest('.delete-file-btn');
                const photoId = btn.getAttribute('data-photo-id');
                const fileName = btn.getAttribute('data-file-name');
                const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

                if (confirm('Delete ' + fileName + '?')) {
                    const formData = new FormData();
                    formData.append('photoId', photoId);
                    if (token) formData.append('__RequestVerificationToken', token);

                    fetch('/DocumentOfficer/DeleteRequirementFile', { method: 'POST', body: formData, headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                    .then(r => r.json())
                    .then(data => {
                        if (data.success) {
                             // Find active modal to refresh files
                             const modal = document.querySelector('.modal.show[id^="docClientModal-"]');
                             if (modal) {
                                  const id = modal.id.replace('docClientModal-', '');
                                  fetch('/DocumentOfficer/GetRequirementFiles?clientId=' + id).then(r=>r.text()).then(h => {
                                      modal.querySelector('#requirement-files-' + id).innerHTML = h;
                                  });
                             }
                        }
                    });
                }
            }
        });

        // File upload handler
        document.getElementById('uploadFilesBtn')?.addEventListener('click', function() {
             const form = document.getElementById('uploadFilesForm');
             const files = document.getElementById('uploadFiles').files;
             if (!files.length) return alert('Select files');

             const formData = new FormData(form);
             const progress = document.getElementById('uploadProgress');
             progress.classList.remove('d-none');

             fetch('/DocumentOfficer/UploadOptionalFiles', { method: 'POST', body: formData, headers: { 'X-Requested-With': 'XMLHttpRequest' } })
             .then(r => r.json())
             .then(data => {
                 if (data.success) {
                     bootstrap.Modal.getInstance(document.getElementById('uploadFilesModal')).hide();
                     const modal = document.querySelector('.modal.show[id^="docClientModal-"]');
                     if (modal) {
                         const id = modal.id.replace('docClientModal-', '');
                         fetch('/DocumentOfficer/GetRequirementFiles?clientId=' + id).then(r=>r.text()).then(h => {
                             modal.querySelector('#requirement-files-' + id).innerHTML = h;
                         });
                     }
                 }
                 progress.classList.add('d-none');
             });
        });
    </script>
}