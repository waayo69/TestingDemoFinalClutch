@model List<UserViewModel>

@{
    ViewData["Title"] = "Users List";
}

<div class="container users-container">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0">Manage Users</h2>
        <a asp-action="AddUser" class="btn btn-success">
            <i class="bi bi-person-plus me-1"></i>Add New User
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-hover mt-2">
            <thead class="table-dark">
                <tr>
                    <th scope="col">Email</th>
                    <th scope="col">Full Name</th>
                    <th scope="col">Role</th>
                    <th scope="col">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Email</td>
                        <td>@user.FullName</td>
                        <td>@user.Role</td>
                        <td>
                            <a asp-action="EditUser" asp-route-id="@user.Id" class="btn btn-primary btn-sm me-2">
                                <i class="bi bi-pencil me-1"></i>Edit
                            </a>
                            <a asp-action="ConfirmDelete" asp-route-id="@user.Id" class="btn btn-danger btn-sm">
                                <i class="bi bi-trash me-1"></i>Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<style>
    .users-container {
        max-width: 1200px;
        margin: 50px auto;
        padding: 30px;
        background: #ffffff;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        border-radius: 12px;
    }

    h2 {
        font-weight: 700;
        color: #2c3e50;
    }

    .table th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.85rem;
        letter-spacing: 0.5px;
    }

    body.dark-mode .users-container {
        background: #23272b;
        color: #f8f9fa;
    }
</style>    